# ===================================================
# MeetWise Backend — .env.example
# SAFE TO COMMIT — không chứa secrets thật
# ===================================================
# Sao chép file này thành .env:
#   cp .env.example .env
# Chỉ điền các biến khi bạn muốn bật real integrations.

# ── ZERO-SETUP SWITCHES (mặc định = false = chạy ngay) ─
USE_LLM=false
USE_FIREBASE=false
USE_GOOGLE_SERVICES=false

# ── App ─────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ── Logging ─────────────────────────────────────────
LOG_LEVEL=INFO

# ── Rate Limiter ────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Timeout ─────────────────────────────────────────
REQUEST_TIMEOUT_SECONDS=10
STEP_TIMEOUT_SECONDS=5

# ── CORS ────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=*

# ── Actions ─────────────────────────────────────────
ACTIONS_ENABLED=true
ACTION_TIMEOUT_SECONDS=5.0

# ─────────────────────────────────────────────────────
# TÙY CHỌN — Bật khi cần real Google integrations
# ─────────────────────────────────────────────────────

# Bật LLM (USE_LLM=true)
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-1.5-flash

# Bật Google Services (USE_GOOGLE_SERVICES=true)
# GOOGLE_CHAT_WEBHOOK_URL=https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=...
# GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json

# Bật Firebase (USE_FIREBASE=true)
# FIREBASE_PROJECT_ID=your-firebase-project-id
