# ============================================================
# MeetWise V2 — Environment Configuration Template
# Created by: Đoàn Hoàng Việt (Việt Gamer)
#
# CÁCH DÙNG:
#   cp .env.example .env
#   Điền giá trị thật vào .env (KHÔNG commit .env lên Git)
# ============================================================

# ── App ──────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Zero-Setup Master Switches ───────────────────
# Đặt False để chạy ngay không cần config gì
USE_LLM=False
USE_FIREBASE=False
USE_GOOGLE_SERVICES=False

# ── Gemini LLM (bật khi USE_LLM=True) ────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Supabase (Phase 2 — Bắt buộc cho Auth + CRUD) ─
# Lấy từ: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
# Lấy từ: Supabase Dashboard → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ── Resend (Email Notifications) ─────────────────
# Lấy từ: resend.com → API Keys
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@meetwise.app

# ── CORS ─────────────────────────────────────────
# Dev: * | Prod: https://meetwise.app,https://www.meetwise.app
CORS_ALLOWED_ORIGINS=*

# ── Rate Limiting ─────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ── Google Workspace (bật khi USE_GOOGLE_SERVICES=True) ─
GOOGLE_CHAT_WEBHOOK_URL=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Firebase (bật khi USE_FIREBASE=True) ─────────
FIREBASE_PROJECT_ID=
